rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function creatingAsSelf() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function notChangingOwner() {
      return request.resource.data.userId == resource.data.userId;
    }

    match /incomes/{id} {
      allow read: if isOwner();
      allow create: if creatingAsSelf();
      allow update: if isOwner() && notChangingOwner();
      allow delete: if isOwner();
    }

    match /expenses/{id} {
      allow read: if isOwner();
      allow create: if creatingAsSelf();
      allow update: if isOwner() && notChangingOwner();
      allow delete: if isOwner();
    }

    match /categories/{id} {
      allow read: if isOwner();
      allow create: if creatingAsSelf();
      allow update: if isOwner() && notChangingOwner();
      allow delete: if isOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
